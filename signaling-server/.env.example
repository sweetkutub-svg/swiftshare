# SwiftShare Signaling Server Environment Configuration
# Copy to .env and set real values before deployment.
# Proprietary & Confidential. All Rights Reserved.

NODE_ENV=production
PORT=3000

# CORS origins (comma separated)
CORS_ORIGINS=https://swiftshare.github.io,http://localhost:8080

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Message size limit (bytes) - strictly enforced. File data must NEVER touch this server.
MAX_MESSAGE_SIZE=1024

# Room expiry time (ms)
ROOM_EXPIRY_MS=86400000

# WebRTC ICE servers (STUN/TURN) - these are public defaults. Replace with paid TURN for Pro.
# Format: JSON array of RTCIceServer objects
ICE_SERVERS=[{"urls":"stun:stun.l.google.com:19302"},{"urls":"stun:stun1.l.google.com:19302"}]
